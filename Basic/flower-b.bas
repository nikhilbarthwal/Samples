   10 CLS: KEY OFF
   20 SCREEN 1
   30 T=100:F=0:K=0
   40 FOR A =0 TO 6.3 STEP .095/2
   50 R=T*SIN((A+F)/10)
   60 X=100+R*COS(A)
   70 Y=100+R*SIN(A)
   95 CIRCLE(X,Y),5,3*RND,3.14,,3.14
  120 F=F-1
  130 NEXT:K=K+1
  140 T=T-10:IF K>=3 THEN K=0:S=S+1:CLS:GOTO 150 :ELSE GOTO 40
  150 IF S>=6 THEN STOP :ELSE GOTO 40
  160 END
