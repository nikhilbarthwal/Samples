   10 REM PRGM BY NIKHIL AULUCK
   20 DIM A$(40)
   30 FOR I=1 TO 40
   40 READ A$(I)
   50 NEXT I
   60 BASE=256:DUR=4
   70 CLS:KEY OFF:PRINT  :PRINT  :PRINT
   80 PRINT "            M U S I C"
   90 PRINT "         Nikhil Barthwal":PRINT  :PRINT  :PRINT "PRESENT BASE FREQUENCY IS:",BASE
  100 PRINT  :PRINT  "INCREASE BASE FREQUENCY BY`SHIFT->`"
  110 PRINT "DECREASE BASE FREQUENCEY BY`SHIFT-<`"
  120 PRINT  :PRINT  :PRINT  :PRINT "PRESS`/'KEY TO END"
  130 PRINT "    MAKE SURE CAPS-LOCK IS NOT ON"
  140 DI=2^(1/12)
  150 AS=1
  160 X$=INPUT $(1)
  170 IF X$="<" THEN BASE=BASE-5:GOTO 70
  180 IF X$=">" THEN BASE=BASE+5:GOTO 70
  190 IF X$="/" THEN END
  200 FOR I=1 TO 40
  210 IF X$=A$(I) THEN AS=I:GOTO 230
  220 NEXT I
  230 SOUND (BASE*DI^AS),(DUR)
  240 GOTO 150
  250 DATA 1,q,2,w,3,e,E,4,r,5,t,T,6,y,7,u,i,i,I,9,o,O,p,P,-,[,=,],\
  260 DATA a,z,s,x,d,c,C,f,v,g,b,h,n,j,m,k
