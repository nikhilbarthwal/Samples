   10 REM cosine
   20 CLS:SCREEN 1,0
   30 LOCATE 1,10:PRINT "PATH OF COSINE CURVE"
   60 FOR X=0 TO 319
   70 PSET(X,99-80*COS(.0174533*X)),3
   80 IF X/50 = INT(X/50) THEN B=12
   90 NEXT X
  100 FOR X=0 TO 319
  110 PRESET (X,99-80*COS(.0174533))
  120 IF X/20 = INT(X/20) THEN B=12
  130 NEXT X
  140 END
