    2 DIM BALL(100):DIM ARR(100)
    5 SCREEN 1
   10 CLS
   20 FOR A= 0 TO 360 STEP 2
   30 P=3.14:M=3
   40 X=50*SIN(A*P/15)
   50 Y=50*COS(A*P/15)
   55 LINE(160,100)-(160,180),3
   60 LINE(160,100)-(X+160,Y+100)
   61 GET(160,100)-(X+160,Y+100),BALL
   62 GET(160,100)-(X+160,Y+100),ARR
   63 PUT(X+90,Y+90),BALL
   64 PUT(X+90,Y+90),ARR
   70 CIRCLE(X+160,Y+100),5
   80 CIRCLE(X+160,Y+80+M),5
   90 FOR G=1 TO 90:NEXT G
  100 NEXT A
