   10 WIDTH 40:SCREEN 1:CLS
   20 FOR L=4 TO 40:FOR I=1 TO 12:FOR J=0 TO 11:K=I+J
   30 LOCATE K,I+9:PRINT CHR$(1)
   40 LOCATE I,K+9:PRINT CHR$(3)
   50 LOCATE 24-I,33-K:PRINT CHR$(5)
   60 LOCATE 24-K,33-I:PRINT CHR$(157)
   70 LOCATE I,33-K:PRINT CHR$(36)
   80 LOCATE 24-K,I+9:PRINT CHR$(64)
   90 LOCATE K,33-I:PRINT CHR$(18)
  100 LOCATE 24-I,K+9:PRINT CHR$(232)
  110 NEXT J:NEXT I:NEXT L
  120 END
