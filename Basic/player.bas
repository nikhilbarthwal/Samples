    1  PRINT AT 5,5 ;"PLAY ANY MUSICAL INSTRUMENT"''' "1. HARMONIUM"''' "2. MANDOLIN "''' "3. MOUTH ORGAN"''' "A S D F G H J K ARE THE KEYS "
    2  INPUT  "TYPE IN YOUR CHOICE NOW "; I$
    3    IF CODE(I$)  < 49 OR CODE I$  >  51 THEN GOTO 2
    4  LET I=VAL(I$)
    5  DIM V$(3,14):REM FOR STORING ENVELOPES
    7  LET V$(1)="06T220" :REM HARMONIUM
    8  LET V$(2)="T240NUX1000W4" : REM MANDOLIN
    9  LET V$(3)="06T240UX300W7" : REM MOUTH ORGAN
   10  DIM W$(8,15):REM FOR STORING NOTES+ENVELOPES
   30  LET W$(1)=V$(I)+"C" : REM SA
   31  LET W$(2)=V$(I)+"D" : REM RE
   32  LET W$(3)=V$(I)+"E" : REM GA
   33  LET W$(4)=V$(I)+"F" : REM MA
   34  LET W$(5)=V$(I)+"G" : REM PA
   35  LET W$(6)=V$(I)+"A" : REM DHA
