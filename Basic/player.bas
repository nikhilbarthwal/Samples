   37  LET W$(8)=V$(I)+"C" : REM SA OF NEXT SAPTAK
   40  LET A$=INKEY$:IF A$=" " THEN GOTO 40: REM SCANNING THE KEYBOARD
   45  IF A$="1" THEN LET I=1 : GOTO 40
   46  IF A$="2" THEN LET I=2 : GOTO 40
   47  IF A$="3" THEN LET I=3 : GOTO 40: REM ON-LINE INSTRUMENT SELECTION
   48  IF CODE(A$) < 97 THEN GOTO 40 : REM CRASH-PROOF
