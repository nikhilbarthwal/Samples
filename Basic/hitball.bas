   10 CLS:SCREEN 1:COLOR 0
   20 PRINT "OBJECT OF THIS GAME IS TO SELECT THE STARTING POSITION FOR BALL"
   30 PRINT "YOU WILL SELEST THE STARTING POSITION FOR BALL BY TYPING A NUMBER FROM 25 TO 180 .YOU WILL SELECT THE DIRECTION BY TYPING NUMBER FROM -8 TO 8 "
   40 IF INKEY$="" THEN GOTO 40
   50 CLS
   60 LET R=4
   70 CIRCLE(4,4),R,3,,,1:PAINT (4,4),3,3
   80 LET B=4+9*INT((2*9+7)/8)
   90 DIM BALL%(INT(B/2))
  100 GET (0,0)-(8,8),BALL%
  110 PUT(0,0),BALL%
  120 RANDOMIZE VAL (RIGHT$(TIME$,2))
  130 LET X1=INT(200*RND)+60
  140 LET Y1=INT(120*RND)+40
  150 LET R1=INT(16*RND)+10
  160 GOSUB 580
  170 GOSUB 650
  180 LET X=5
  190 LOCATE 2,2
  200 INPUT "SELECT STARTING POINT(25-180)",Y
  210 IF Y<25 OR Y>180 THEN LOCATE 2,2:PRINT SPACE$(38):GOTO 190
  220 LOCATE 3,2
  230 INPUT "SELECT STARTING DIRECTION (-8-8)",YCHANGE
  240 IF YCHANGE < -8 OR YCHANGE >8 THEN LOCATE 3,2: PRINT SPACE$(38): GOTO 220
  250 LET XCHANGE=9-ABS(YCHANGE)
  260 LOCATE  23,5
  270 PRINT "STARTING POSITION AND DIRECTION"
  280 PUT (X,Y),BALL%
  290 LINE (X+R,Y+R)-STEP (5*XCHANGE,5*YCHANGE)
  300 LOCATE 24,5
  310 PRINT "PRESS Any kEy tO cOnTinUe"
  320 IF INKEY$="" THEN 320
  330 CLS
  340 GOSUB  580
  350 GOSUB   650
  360 LET C=0
  370 WHILE+ (X+R-X1)^2+(Y+R-Y1)^2> (R+R1)^2 AND C<20
  380 PUT(X,Y),BALL%
  390 FOR DELAY = 1 TO 10 :NEXT DELAY
  400 PUT (X,Y),BALL%
  410 LET X=X+XCHANGE:Y=Y+YCHANGE
  420 IF  X>=307 THEN  C=C+1:PRINT CHR$(7):X=306:XCHANGE=-XCHANGE
  430 IF X<=4 THEN C=C+1:PRINT CHR$(7):X=5    :XCHANGE=-XCHANGE
  440 IF Y>=187 THEN C=C+1:PRINT CHR$(7):Y=186:YCHANGE=-YCHANGE
  450 IF Y<=4 THEN C=C+1:PRINT CHR$(7):Y=5:YCHANGE=-YCHANGE
  460 WEND
  470 IF C=20 THEN LOCATE 23,8:PRINT "20 REBOUNDS WITH NO HIT":GOTO
  480 LINE(X1-30,Y1)-(X1+30,Y1),1
  490 LINE(X1-20,Y1+20)-(X1+20,Y1-20),1
  500 LINE(X1-20,Y1-20)-(X1+20,Y1+20),1
  510 LINE(X1,Y1-30)-(X1,Y1+30),1
  520 LOCATE 23,8
  530 PRINT "A HIT AFTER ";C;"REBOUNDS";
  540 FOR I=1 TO 10 STEP 1:PRINT CHR$(7);:NEXT I
  550 IF INKEY$="" THEN 550
  560 SCREEN 0:WIDTH 80
  570 END
  580 REM LKDFGJKLFHKLMRKLTY
  590 REM SDHJFJSD
  600 REM SDCJSDJKSDF
  610 FOR W=0 TO 4
  620 LINE(W,W)-(319-W,199-W),2,B
  630 NEXT W
  640 RETURN
  650 REM FKLFXCVJK
  660 REM SDJKR
  670 CIRCLE(X1,Y1),R1,1,,,1:PAINT(X1,Y1),3,1
  680 CIRCLE (X1,Y1),2*R1/3,1,,,1
  690 CIRCLE(X1,Y1),R1/3,1,,,1
  700 CIRCLE(X1,Y1),0,1
  710 RETURN
