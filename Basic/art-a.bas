   10 CLS
   20 SCREEN 1
   30 FOR A=1 TO 720 STEP 4:M=A/4
   40 B=M*SIN(A*3.14/180)
   50 C=M*COS(A*3.14/180)
   60 D=M*SIN((A+90)*3.14/180)
   70 E=M*COS((A+90)*3.14/180)
   80 F=M*SIN((A+180)*3.14/180)
   90 G=M*COS((A+180)*3.14/180)
  100 H=M*SIN((A+270)*3.14/180)
  110 I=M*COS((A+270)*3.14/180)
  120 LINE(B+160,C+100)-(D+160,E+100)
  130 LINE(D+160,E+100)-(F+160,G+100)
  140 LINE(F+160,G+100)-(H+160,I+100)
  150 LINE(H+160,I+100)-(B+160,C+100)
  160 NEXT A
